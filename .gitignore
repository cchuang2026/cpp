.vscode
*.dSYM





# ==============================
# Official C++ Core Compile Artifacts
# Source: github/gitignore/C++.gitignore
# ==============================
# Dependency files generated by compilers
*.d

# Object files
*.slo
*.lo
*.o
*.obj

# Precompiled headers
*.gch
*.pch
*.pii

# Dynamic shared libraries
*.so
*.so.*
*.dylib
*.dll

# Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.elf

# Linker debug / intermediate files
*.ilk
*.pdb
*.map
*.res
*.rc.user

# Coverage profiling (gcov)
*.gcno
*.gcda
coverage/

# ==============================
# CMake Build System (most common for C++)
# ==============================
build/
Build/
build-*/
cmake-build-*/      # CLion default cmake folders
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
install_manifest.txt
compile_commands.json
Makefile
*.cmake.user
CMakeUserPresets.json

# ==============================
# Visual Studio MSVC Project
# ==============================
.vs/
[Dd]ebug/
[Rr]elease/
[Xx]64/
[Xx]86/
[Oo]bj/
[Bb]in/
*.vcxproj.user
*.vcxproj.filters
*.suo
*.sdf
*.sln.docstates
*.VC.db
*.opendb
TestResults/
*.trx
*.coverage

# ==============================
# JetBrains CLion / Rider
# ==============================
.idea/
cmake-build-debug/
cmake-build-release/
cmake-build-relwithdebinfo/
*.iml
*.iws
*.ipr
out/

# ==============================
# VS Code
# ==============================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/c_cpp_properties.json
.vscode/extensions.json.lock

# ==============================
# Package Managers & Dependencies
# ==============================
vcpkg_installed/
vcpkg/buildtrees/
vcpkg/packages/
conan/
conanbuildinfo.*
conaninfo.txt
_packages/
vendor/

